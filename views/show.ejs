<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Link</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Pristina;
        }

        body {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: url("https://kinsta.com/wp-content/uploads/2023/12/create-url-shortener-with-python-1024x512.png") no-repeat center/cover fixed;
        }

        section {
            position: relative;
            width: 80%;
            max-width: 500px;
            border: 2px solid #ffffff80;
            border-radius: 20px;
            backdrop-filter: blur(15px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 4rem 3rem;
        }

        h1 {
            font-size: 2rem;
            text-align: center;
            color: #fff;
        }

        .input_container {
            position: relative;
            margin: 30px 0;
            width: 100%;
            border-bottom: 2px solid #ffffff80;
        }

        form {
            width: 100%;
        }

        .input_container label {
            position: absolute;
            right: 8px;
            color: #fff;
            width: 30px;
            top: 20px;
        }



        .input_container input::placeholder {
            color: #00000062;
        }

        .input_container input {
            width: 100%;
            height: 60px;
            background: transparent;
            border: none;
            outline: none;
            font-size: 1rem;
            padding: 0 35px 0 5px;
            color: #fff;
            font-weight: 700;
            font-family: inherit;

        }



        #copy_button {
            width: 100%;
            background-color: #fff;
            border: none;
            outline: none;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 700;
            font-family: inherit;
            padding: .7rem 0;
            transition: all 0.4s ease;
            border-radius: 40px;
        }

        #copy_button:hover {
            background-color: #0000002d;
            color: white;
            box-shadow: inset 0 3px white;
        }

        .btn {
            background: #ccebf3;
            border: 6px solid darken(#ccebf3, 10%);
            border-radius: .4rem;
            outline: none;
            padding: 1rem;
            text-transform: lowercase;
        }


        .notify {
            border-radius: .4rem;
            font-weight: 300;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }




        .notify__close {
            color: inherit;
            font-size: 2.1rem;
            font-weight: 300;
            line-height: 1;
            opacity: .5;
            padding: 0 .4rem;
            /* position: absolute;
            right: .8rem; */

            &:hover {
                opacity: 1;
            }

            button& {
                background: transparent;
                border: 0;
                outline: none;
                -webkit-appearance: none;
            }
        }

        .notify__icon {
            margin-right: .4rem;
        }

        .notify-container {
            position: absolute;
            right: 40px;
            top: 0.6rem;
            background-color: #e1fef2ad;
            width: 300px;


        }
    </style>
</head>

<body>
    <div class="notify-container"></div>
    <section>
        <h1>Old Url</h1>
        <div class="input_container">
            <label for="url">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                </svg>
            </label>
            <input disabled value="<%= existingUrl.originalUrl %>" type="text">
        </div>
        <h1>New Url</h1>
        <div class="input_container">
            <label for="url">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                    stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                </svg>
            </label>
            <input id="copy" disabled value="<%= existingUrl.shortenedUrl %>" type="text">
        </div>
        <button id="copy_button">Copy</button>

        <div id="notifications" style="display: none;">

            <div class="notify notify--success">
                <svg style="width: 30px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                    stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                </svg>
                <p> Link copied succesfully.</p>
                <button type="button" class="notify__close" data-dismiss="notify" aria-label="Close"><span
                        aria-hidden="true">&times;</span></button>
            </div>
    </section>
</body>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/latest/TweenMax.min.js"></script>
<script>
    const copy = document.querySelector('#copy_button');
    const notification = document.querySelector('#notifications .notify');
    const notifyButton = document.querySelector('#notify-button');
    const notifyContainer = document.querySelector('.notify-container');
    const notifyBottomMargin = 6;
    const notifyDelay = 6;

    copy.addEventListener('click', () => {
        const copyText = document.querySelector('#copy').value;
        navigator.clipboard.writeText(copyText);
        addNotification();
    });


    function showNotification(item) {
        TweenMax.set(item, {
            marginBottom: notifyBottomMargin,
            marginTop: -item.offsetHeight,
            opacity: 0.25
        });
        TweenMax.to(item, 0.5, {
            marginTop: 0,
            opacity: 1,
            ease: Expo.easeOut,
            onComplete: function () {
                hideNotification(item);
            }
        });
    }


    function hideNotification(item, delay = true) {
        TweenMax.to(item, 0.5, {
            opacity: 0,
            marginTop: -item.offsetHeight - notifyBottomMargin,
            delay: delay ? notifyDelay : 0,
            onComplete: function () {
                item.parentNode.removeChild(item);
            }
        });
    }


    function addNotification() {
        newNotification = notification.cloneNode(true),
            close = newNotification.querySelector('.notify__close');
        close.addEventListener('click', () => {
            hideNotification(newNotification, false);
        });
        notifyContainer.insertBefore(newNotification, notifyContainer.firstChild);
        showNotification(newNotification);
    }

</script>

</html>